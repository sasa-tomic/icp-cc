    },
    {
      "id": "icp_group_by_canonical",
      "helper": "icp_group_by",
      "args": [ [ { "c": "NY" }, { "c": "LA" }, { "c": "NY" } ], "c" ],
      "expectedJs": {
        "NY": [ { "c": "NY" }, { "c": "NY" } ],
        "LA": [ { "c": "LA" } ]
      },
      "expectedLua": null
    },
    {
      "id": "icp_group_by_two_bucket",
      "helper": "icp_group_by",
      "args": [
        [ { "c": "NY", "n": "A" }, { "c": "LA", "n": "B" }, { "c": "NY", "n": "C" } ],
        "c"
      ],
      "expectedJs": {
        "NY": [ { "c": "NY", "n": "A" }, { "c": "NY", "n": "C" } ],
        "LA": [ { "c": "LA", "n": "B" } ]
      },
      "expectedLua": null
    }
  ]
}
