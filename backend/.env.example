# Local Development Environment Configuration
# This file is for local development (cargo run, just api-up)

# Database Configuration (SQLite for Phase 1)
DATABASE_URL=sqlite:./data/dev.db

# Server Configuration
PORT=8080

# Environment
ENVIRONMENT=development

# Logging
RUST_LOG=info,icp_marketplace_api=debug

# Admin Operations
# Generate a secure random token for production
ADMIN_TOKEN=change-me-in-production

# WebAuthn (Passkey) Relying Party
# REQUIRED for production: must point at the public hostname, not localhost.
# Leaving these at localhost in production silently breaks passkey login.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:58000

# Production Deployment Note:
# For production deployment with Docker + CF Tunnel:
# - Copy .env.tunnel.example to .env
# - Add your TUNNEL_TOKEN
# - Run: just docker-deploy-prod
