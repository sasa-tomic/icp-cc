{
  "name": "@icp-cc/marketplace-sdk",
  "version": "0.1.0",
  "description": "Typed SDK + contract for ICP marketplace scripts (TypeScript on QuickJS)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "build:samples": "node scripts/build-samples.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@jitl/quickjs-singlefile-browser-release-sync": "^0.32.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.2",
    "quickjs-emscripten": "^0.32.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
