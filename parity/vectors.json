    {
      "id": "icp_format_icp_whole_divergence",
      "helper": "icp_format_icp",
      "args": [ 100000000, 8 ],
      "expectedJs": "1",
      "expectedLua": "1.0",
      "notes": "Documented divergence: JS String(1.0) drops the trailing zero ('1') while Lua tostring(1.0) keeps it ('1.0'). Non-whole results agree."
    },
    {
      "id": "icp_format_timestamp_canonical",
      "helper": "icp_format_timestamp",
