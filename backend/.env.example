# ICP Marketplace API вЂ” environment configuration
#
# This file is the LOCAL DEVELOPMENT template (used by `cargo run`, `just api-dev-up`).
# It is NOT read by Docker. Copy it to `.env` for local dev:
#   cp .env.example .env
#
# For PRODUCTION (Docker + Cloudflare Tunnel) see PROD_DEPLOYMENT.md and use
# `.env.tunnel.example` as the template for `.env` (it adds TUNNEL_TOKEN).
# Production overrides every var below via docker-compose.prod.yml interpolation.

# в”Ђв”Ђ Database в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# SQLite location. Dev points at ./data/dev.db; prod uses /data/marketplace-prod.db.
DATABASE_URL=sqlite:./data/dev.db

# в”Ђв”Ђ Server в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Dev listens on 8080 (or 0 = auto-assign via `just api-dev-up`). Prod uses 58000.
PORT=8080

# Marks a non-dev run. MUST be `production` in prod вЂ” only `development` enables
# the destructive /api/dev/reset-database endpoint.
ENVIRONMENT=development

# в”Ђв”Ђ Logging в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# tracing EnvFilter. Prod default is plain `info`.
RUST_LOG=info,icp_marketplace_api=debug

# в”Ђв”Ђ Admin Operations в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Bearer token guarding the /api/v1/admin/* routes (key disable, recovery-key
# injection). In dev the placeholder is fine. IN PRODUCTION YOU MUST OVERRIDE
# THIS: generate a long random secret and set ADMIN_TOKEN in your prod `.env`.
# The code falls back to this exact value when the var is unset (see
# admin_auth.rs) вЂ” never ship prod with the placeholder. (Tracked gap: this
# fallback is currently a single `warn!`, not a loud boot banner вЂ” see
# DEPLOY_RUNBOOK.md "Known operational gaps".)
ADMIN_TOKEN=change-me-in-production

# в”Ђв”Ђ WebAuthn (Passkey) Relying Party в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Dev points at localhost. IN PRODUCTION these MUST point at the public host:
#   WEBAUTHN_RP_ID=icp-mp.kalaj.org
#   WEBAUTHN_RP_ORIGIN=https://icp-mp.kalaj.org
# (scheme + host, NO port вЂ” the user-facing origin, not the internal :58100).
# Leaving localhost in prod silently breaks passkey registration/login; on boot
# the API prints a loud `[!!] PRODUCTION PASSKEY MISCONFIGURATION` banner.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:58000

# в”Ђв”Ђ ICPay payment integration (paid-script entitlement) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# REQUIRED for the live PoC / production. When ANY of these is unset the
# marketplace still boots and browses вЂ” only the payment endpoints themselves
# fail loudly:
#   - GET  /api/v1/payments/icpay/config   в†’ 503 "ICPAY_PUBLISHABLE_KEY not configured"
#   - POST /api/v1/payments/icpay/webhook  в†’ 500 "ICPAY_WEBHOOK_SECRET not configured"
# On boot the API logs a `tracing::warn!` naming the missing vars.
#
# Get these from your ICPay dashboard (https://dashboard.icpay.org):
#   ICPAY_PUBLISHABLE_KEY  вЂ” browser-safe, returned to clients by /config
#   ICPAY_SECRET_KEY       вЂ” server-only (intent creation / refund flows)
#   ICPAY_WEBHOOK_SECRET   вЂ” HMAC-SHA256 shared secret for webhook verification
#
# For LOCAL DEV / PoC you can use any non-empty placeholder strings (the
# webhook verifier just needs the secret to match what you sign with). The
# human MUST set real values before the live PoC.
ICPAY_PUBLISHABLE_KEY=
ICPAY_SECRET_KEY=
ICPAY_WEBHOOK_SECRET=

# в”Ђв”Ђ Production deployment в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Prod runs under Docker Compose + Cloudflare Tunnel:
#   1. cp .env.tunnel.example .env      (adds TUNNEL_TOKEN, the CF tunnel secret)
#   2. set the prod overrides above (WEBAUTHN_RP_*, ADMIN_TOKEN)
#   3. just docker-deploy-prod          (or: docker compose -f docker-compose.prod.yml up -d)
# See PROD_DEPLOYMENT.md (concepts) and DEPLOY_RUNBOOK.md (step-by-step ops).
