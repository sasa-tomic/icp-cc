      "expectedJs": [ { "c": "NY" }, { "c": "NY" } ],
      "expectedLua": null
    },
    {
      "id": "icp_sort_items_ascending",
      "helper": "icp_sort_items",
      "args": [ [ { "n": "C" }, { "n": "A" }, { "n": "B" } ], "n", true ],
      "expectedJs": [ { "n": "A" }, { "n": "B" }, { "n": "C" } ],
      "expectedLua": null
    },
    {
      "id": "icp_sort_items_descending",
      "helper": "icp_sort_items",
      "args": [ [ { "n": "A" }, { "n": "C" }, { "n": "B" } ], "n", false ],
      "expectedJs": [ { "n": "C" }, { "n": "B" }, { "n": "A" } ],
